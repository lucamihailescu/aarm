{
  "openapi": "3.0.0",
  "info": {
    "title": "AARM Platform API",
    "version": "1.0.0",
    "description": "API documentation for the AARM Platform including Action Mediation, Telemetry, and Policy Management."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api/mediate": {
      "post": {
        "summary": "Mediate an action",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sessionId": { "type": "string" },
                  "intent": { "type": "string" },
                  "userPrompt": { "type": "string" },
                  "actionType": { "type": "string" },
                  "parameters": { "type": "object" },
                  "businessUnit": { "type": "string" },
                  "application": { "type": "string" },
                  "principalId": { "type": "string" }
                },
                "required": ["sessionId", "intent", "userPrompt", "actionType"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mediation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "executionStatus": { "type": "string" },
                    "receipt": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/approvals": {
      "get": {
        "summary": "Get pending approvals",
        "responses": {
          "200": {
            "description": "List of pending approvals"
          }
        }
      }
    },
    "/api/approvals/{id}": {
      "post": {
        "summary": "Resolve an approval",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "approved": { "type": "boolean" },
                  "reviewer": { "type": "string" }
                },
                "required": ["approved"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Approval resolved" }
        }
      }
    },
    "/api/telemetry": {
      "get": {
        "summary": "Get recent telemetry events",
        "responses": {
          "200": { "description": "List of telemetry events" }
        }
      }
    },
    "/api/pde/namespaces": {
      "get": {
        "summary": "Get all namespaces for Policy Engine",
        "responses": {
          "200": { "description": "List of namespaces" }
        }
      }
    },
    "/api/pde/policies": {
      "get": {
        "summary": "Get policies for a namespace",
        "parameters": [
          {
            "in": "query",
            "name": "namespace",
            "schema": { "type": "string", "default": "Default::Global" }
          }
        ],
        "responses": {
          "200": { "description": "Cedar policies as a string" }
        }
      },
      "post": {
        "summary": "Set policies for a namespace",
        "parameters": [
          {
            "in": "query",
            "name": "namespace",
            "schema": { "type": "string", "default": "Default::Global" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "string" }
            }
          }
        },
        "responses": {
          "200": { "description": "Policies updated successfully" }
        }
      }
    },
    "/api/pde/entities": {
      "get": {
        "summary": "Get entities for a namespace",
        "parameters": [
          {
            "in": "query",
            "name": "namespace",
            "schema": { "type": "string", "default": "Default::Global" }
          }
        ],
        "responses": {
          "200": { "description": "Entities JSON array" }
        }
      },
      "post": {
        "summary": "Set entities for a namespace",
        "parameters": [
          {
            "in": "query",
            "name": "namespace",
            "schema": { "type": "string", "default": "Default::Global" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "array", "items": { "type": "object" } }
            }
          }
        },
        "responses": {
          "200": { "description": "Entities updated successfully" }
        }
      }
    }
  }
}
